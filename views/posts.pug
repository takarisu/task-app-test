doctype html
html(lang="ja")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")

    link(
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    )

    link(
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.0/font/bootstrap-icons.css"
    )

    link(rel="stylesheet" href="style.css")

    title To Do List

  body
    nav.navbar.navbar-expand-lg.bg-dark.border-bottom.border-body.main-navbar(data-bs-theme="dark")
      .container-fluid
        a.navbar-brand.me-5.ms-4(href="/posts") To Do List

        #navbarColor01.collapse.navbar-collapse
          ul.navbar-nav.me-auto.mb-2.mb-lg-0
            li.nav-item.me-2
              a.nav-link(href="#") 重要タスク
            li.nav-item.me-2
              a.nav-link(href="#") 小タスク
            li.nav-item.me-2
              a.nav-link(href="#") 中タスク
            li.nav-item.me-2
              a.nav-link(href="#") 大タスク
            li.nav-item.dropdown
              a.nav-link.dropdown-toggle(
                href="#"
                role="button"
                data-bs-toggle="dropdown"
                aria-expanded="false"
              )

              ul.dropdown-menu
                if hideCompleted
                  li
                    a.dropdown-item(href="/posts")
                      | 完了済みのタスクを表示
                else
                  li
                    a.dropdown-item(href="/posts?completed=hide")
                      | 完了済みのタスクを非表示

                li
                  hr.dropdown-divider

                li
                  a.dropdown-item(href="/logout")
                    | ログアウト

          form.d-flex.w-50(method="post" action="/posts")
            input.form-control.me-2(
              type="text"
              name="content"
              placeholder="タスクを追加"
            )
            input(type="hidden" name="oneTimeToken" value=oneTimeToken)
            button(type="submit").btn.btn-primary
              i.bi-send

    main.container.mt-4
      each post in posts
        div.card.my-3
          div.card-body.d-flex.justify-content-between.align-items-center
            div

              if post.completed
                h5.card-title.text-decoration-line-through.text-muted #{post.content}
              else
                h5.card-title #{post.content}

              small.text-muted

                if post.pinned
                  i.bi-pin-angle-fill.text-primary.me-1

                if post.completed
                  i.bi-check-circle-fill.text-success.me-1

                | #{post.postedBy}
                |  / #{post.relativeCreatedAt}

            div.d-flex.gap-2

              if !post.completed
                form(method="post" action="/posts/pin")
                  input(type="hidden" name="id" value=post.id)
                  button(type="submit").btn.btn-outline-primary.btn-sm
                    if post.pinned
                      i.bi-pin-angle-fill
                    else
                      i.bi-pin-angle

                form(method="post" action="/posts/complete")
                  input(type="hidden" name="id" value=post.id)
                  button(type="submit").btn.btn-outline-success.btn-sm
                    i.bi-check-lg

              form(method="post" action="/posts/delete")
                input(type="hidden" name="id" value=post.id)
                button(type="submit").btn.btn-outline-danger.btn-sm
                  i.bi-trash

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
    script(src="nn-chat.js")